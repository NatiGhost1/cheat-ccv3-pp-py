"""Type stubs for cheat-ccv3-pp-py

Provides type hints and autocomplete support for IDEs.
"""

from typing import Optional, Union

class Beatmap:
    """Beatmap parsed from .osu file"""

    def __init__(
        self,
        *,
        path: Optional[str] = None,
        content: Optional[str] = None,
        bytes: Optional[bytes] = None,
    ) -> None: ...
    
    @property
    def mode(self) -> str: ...
    @property
    def ar(self) -> float: ...
    @property
    def cs(self) -> float: ...
    @property
    def hp(self) -> float: ...
    @property
    def od(self) -> float: ...
    @property
    def bpm(self) -> float: ...
    @property
    def n_circles(self) -> int: ...
    @property
    def n_sliders(self) -> int: ...
    @property
    def n_spinners(self) -> int: ...
    
    def stars(self) -> Difficulty: ...
    def pp(self) -> Performance: ...
    def max_pp(self, mods: int) -> PerformanceAttributes: ...
    def max_stars(self, mods: int) -> DifficultyAttributes: ...

class Difficulty:
    """Calculate star rating and difficulty metrics"""

    def __init__(
        self,
        beatmap: Beatmap,
        *,
        mods: int = 0,
        passed_objects: Optional[int] = None,
        clock_rate: Optional[float] = None,
        is_convert: Optional[bool] = None,
    ) -> None: ...
    
    def mods(self, mods: int) -> Difficulty: ...
    def passed_objects(self, count: int) -> Difficulty: ...
    def clock_rate(self, rate: float) -> Difficulty: ...
    def is_convert(self, is_convert: bool) -> Difficulty: ...
    def calculate(self) -> DifficultyAttributes: ...

