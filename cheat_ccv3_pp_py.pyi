class Strains:
    """Strain values from difficulty calculation"""

    def __init__(
        self,
        aim: Optional[float],
        speed: Optional[float],
        flashlight: Optional[float],
    ) -> None: ...
    
    @property
    def aim(self) -> Optional[float]: ...
    @property
    def speed(self) -> Optional[float]: ...
    @property
    def flashlight(self) -> Optional[float]: ...

class GameMods:
    """Game modifiers bitmask"""

    def __init__(self, bits: int) -> None: ...
    
    @property
    def bits(self) -> int: ...
    
    def contains(self, mod_bits: int) -> bool: ...
    def add(self, mod_bits: int) -> None: ...
    def remove(self, mod_bits: int) -> None: ...

class ParseError(ValueError):
    """Raised when beatmap parsing fails"""

class ArgsError(TypeError):
    """Raised when invalid arguments are passed"""

