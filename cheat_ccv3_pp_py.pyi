class Performance:
    """Calculate performance points and metrics"""

    def __init__(
        self,
        beatmap: Beatmap,
        *,
        mods: int = 0,
        combo: Optional[int] = None,
        accuracy: Optional[float] = None,
        misses: Optional[int] = None,
        n300: Optional[int] = None,
        n100: Optional[int] = None,
        n50: Optional[int] = None,
        n_katu: Optional[int] = None,
        n_geki: Optional[int] = None,
        passed_objects: Optional[int] = None,
        clock_rate: Optional[float] = None,
        is_convert: Optional[bool] = None,
    ) -> None: ...
    
    def mods(self, mods: int) -> Performance: ...
    def combo(self, combo: int) -> Performance: ...
    def accuracy(self, acc: float) -> Performance: ...
    def misses(self, count: int) -> Performance: ...
    def n_misses(self, count: int) -> Performance: ...
    def n300(self, count: int) -> Performance: ...
    def n100(self, count: int) -> Performance: ...
    def n50(self, count: int) -> Performance: ...
    def n_katu(self, count: int) -> Performance: ...
    def n_geki(self, count: int) -> Performance: ...
    def passed_objects(self, count: int) -> Performance: ...
    def clock_rate(self, rate: float) -> Performance: ...
    def is_convert(self, is_convert: bool) -> Performance: ...
    def calculate(self) -> PerformanceAttributes: ...

class PerformanceAttributes:
    """Result of performance calculation"""

    @property
    def pp(self) -> float: ...
    @property
    def stars(self) -> float: ...
    @property
    def max_combo(self) -> int: ...
    
    # osu! & taiko
    @property
    def pp_acc(self) -> Optional[float]: ...
    
    # osu!
    @property
    def pp_aim(self) -> Optional[float]: ...
    @property
    def pp_speed(self) -> Optional[float]: ...
    @property
    def pp_flashlight(self) -> Optional[float]: ...
    
    # taiko & mania
    @property
    def pp_difficulty(self) -> Optional[float]: ...
    
    # osu! & taiko
    @property
    def effective_miss_count(self) -> Optional[float]: ...
    
    @property
    def difficulty(self) -> DifficultyAttributes: ...

